{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Timelog",
  "title": "Timelog",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "taskId": {
      "type": "string"
    },
    "userId": {
      "type": "string"
    },
    "hours": {
      "type": "number",
      "format": "float",
      "description": "Number of hours logged"
    },
    "createdDate": {
      "type": "string",
      "format": "date-time"
    },
    "trackedDate": {
      "type": "string",
      "format": "date",
      "description": "Date the time was tracked"
    },
    "comment": {
      "type": "string"
    }
  }
}