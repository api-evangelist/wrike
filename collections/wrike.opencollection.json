  "request": {
    "auth": {
      "type": "oauth2",
      "flow": "authorization_code",
      "authorizationUrl": "https://www.wrike.com/oauth2/authorize",
      "accessTokenUrl": "https://www.wrike.com/oauth2/token",
      "credentials": {
        "clientId": "{{clientId}}",
